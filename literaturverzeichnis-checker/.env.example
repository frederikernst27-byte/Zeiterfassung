# --- KI-Fallback (optional) ---
# Wenn USE_AI=false, läuft nur die kostenlose API-Prüfung (CrossRef/OpenAlex/Semantic Scholar).
USE_AI=false
# openrouter oder gemini
AI_PROVIDER=openrouter

# OpenRouter: Account auf https://openrouter.ai anlegen, Key kostenlos.
# Es wird ein ":online"-Modell genutzt (Websuche), z.B. ein aktuell kostenloses Modell.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Alternative: Google AI Studio Key für Gemini 2.5 Flash mit Search-Grounding
GEMINI_API_KEY=

# --- E-Mail-Bot (nur für email_bot.py nötig) ---
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Wie oft (Sekunden) das Postfach geprüft wird
POLL_INTERVAL_SECONDS=60
